# Orchestration Environment Variables
# Copy this file to .env and configure for your environment

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/chatbot
POSTGRES_PASSWORD=postgres
POSTGRES_USER=postgres
POSTGRES_DB=chatbot

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Webhook Configuration
WEBHOOK_SECRET=change-this-to-a-secure-random-string
WEBHOOK_PORT=9000

# Monitoring
GRAFANA_PASSWORD=admin
GRAFANA_USER=admin
PROMETHEUS_PORT=9090
LOKI_PORT=3100

# Object Storage (MinIO)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=localhost:9002

# Secrets Management (Vault)
VAULT_ROOT_TOKEN=root
VAULT_ADDR=http://localhost:8200

# Database Management (pgAdmin)
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin

# Code Quality (SonarQube)
SONAR_HOST_URL=http://localhost:9900
SONAR_TOKEN=

# Email Testing (Mailhog)
SMTP_HOST=localhost
SMTP_PORT=1025

# Jaeger Tracing
JAEGER_AGENT_HOST=localhost
JAEGER_AGENT_PORT=6831

# Application
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Deployment (Vercel)
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# Security Scanning
SNYK_TOKEN=

# GitHub Integration
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=

# GitLab Integration
GITLAB_TOKEN=
GITLAB_WEBHOOK_SECRET=

# Feature Flags
ENABLE_MCP_SERVER=true
ENABLE_WEBHOOK_HANDLER=true
ENABLE_ORCHESTRATION=true
ENABLE_MONITORING=true
ENABLE_TRACING=true

# Performance
MAX_WORKERS=4
TASK_QUEUE_SIZE=100
WORKFLOW_TIMEOUT=300000

# Logging
LOG_FORMAT=json
LOG_DESTINATION=stdout
ENABLE_LOG_SHIPPING=true

# Metrics
METRICS_ENABLED=true
METRICS_PORT=9100
METRICS_PATH=/metrics

# Rate Limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

# Session
SESSION_SECRET=change-this-to-a-secure-random-string
SESSION_MAX_AGE=86400000

# Cache
CACHE_TTL=3600
CACHE_MAX_SIZE=100

# Network
NETWORK_TIMEOUT=30000
MAX_RETRIES=3
RETRY_DELAY=1000
