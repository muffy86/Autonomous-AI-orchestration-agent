# Security Configuration Template
# Copy this to .env.local and fill in the values

# Authentication
AUTH_SECRET=your-super-secure-auth-secret-here-minimum-32-characters
NEXTAUTH_URL=http://localhost:3000

# Database
DATABASE_URL=your-database-connection-string

# API Keys (if needed)
OPENAI_API_KEY=your-openai-api-key
XAI_API_KEY=your-xai-api-key

# Security Settings
RATE_LIMIT_ENABLED=true
CSRF_PROTECTION_ENABLED=true
SECURITY_HEADERS_ENABLED=true

# Logging
LOG_LEVEL=info
SECURITY_LOG_ENABLED=true

# File Upload
MAX_FILE_SIZE=10485760  # 10MB in bytes
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf,text/plain

# Session Configuration
SESSION_MAX_AGE=86400  # 24 hours in seconds
SESSION_UPDATE_AGE=3600  # 1 hour in seconds

# Rate Limiting Configuration
RATE_LIMIT_API_MAX=100
RATE_LIMIT_API_WINDOW=900000  # 15 minutes in milliseconds
RATE_LIMIT_AUTH_MAX=5
RATE_LIMIT_AUTH_WINDOW=900000  # 15 minutes in milliseconds
RATE_LIMIT_CHAT_MAX=20
RATE_LIMIT_CHAT_WINDOW=60000  # 1 minute in milliseconds

# Content Security Policy
CSP_ENABLED=true
CSP_REPORT_ONLY=false

# HTTPS Configuration (for production)
FORCE_HTTPS=false
HSTS_MAX_AGE=31536000  # 1 year in seconds

# Monitoring
SECURITY_MONITORING_ENABLED=true
FAILED_LOGIN_THRESHOLD=5
FAILED_LOGIN_WINDOW=900000  # 15 minutes in milliseconds