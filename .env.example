# Autonomous Agent OS Configuration

# ============================================================================
# AI Model Providers
# ============================================================================

# OpenAI
OPENAI_API_KEY=sk-...

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# xAI (Grok)
XAI_API_KEY=xai-...

# Google AI
GOOGLE_AI_API_KEY=...

# Public AI (Apertus)
PUBLIC_AI_API_KEY=...
PUBLIC_AI_BASE_URL=https://api.publicai.co/v1

# ============================================================================
# Blockchain Configuration
# ============================================================================

# Ethereum
ETHEREUM_RPC_URL=https://eth.llamarpc.com
ETHEREUM_PRIVATE_KEY=0x...

# Polygon
POLYGON_RPC_URL=https://polygon-rpc.com
POLYGON_PRIVATE_KEY=0x...

# Solana
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_PRIVATE_KEY=...

# Wallet Configuration
DEFAULT_WALLET_ADDRESS=0x...

# ============================================================================
# External Services
# ============================================================================

# Email Service
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=...
SMTP_PASSWORD=...

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/agentdb

# Redis (for caching)
REDIS_URL=redis://localhost:6379

# ============================================================================
# Pipeline & Deployment
# ============================================================================

# Docker Registry
DOCKER_REGISTRY_URL=registry.example.com
DOCKER_USERNAME=...
DOCKER_PASSWORD=...

# Kubernetes
KUBECONFIG_PATH=~/.kube/config
K8S_NAMESPACE=default

# Deployment Notifications
DEPLOYMENT_WEBHOOK_URL=https://hooks.slack.com/services/...

# ============================================================================
# Monitoring & Observability
# ============================================================================

# Metrics Endpoint
METRICS_ENABLED=true
METRICS_PORT=9090

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# ============================================================================
# Security
# ============================================================================

# API Authentication
API_SECRET_KEY=...
JWT_SECRET=...

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

# ============================================================================
# Agent Configuration
# ============================================================================

# Orchestration
ORCHESTRATION_STRATEGY=autonomous
AUTO_EXECUTION_ENABLED=true
MAX_CONCURRENT_TASKS=10

# Vision
SCREEN_CAPTURE_ENABLED=true
SCREEN_CAPTURE_INTERVAL=1000
ENABLE_OCR=true
ENABLE_OBJECT_DETECTION=false

# Tools
ENABLE_WEB_SEARCH=true
ENABLE_CODE_EXECUTION=true
ENABLE_FILE_SYSTEM=true

# ============================================================================
# Development
# ============================================================================

NODE_ENV=development
DEBUG=true
