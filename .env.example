# Autonomous Agent OS Configuration

# ============================================================================
# AI Model Providers
# ============================================================================

# OpenAI
OPENAI_API_KEY=sk-...

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# xAI (Grok)
XAI_API_KEY=xai-...

# Google AI
GOOGLE_AI_API_KEY=...

# Public AI (Sovereign AI Infrastructure)
# Sign up at https://platform.publicai.co
# Nonprofit platform providing access to sovereign AI models
# Model: swiss-ai/apertus-8b-instruct (Apache 2.0 licensed)
# Features: 65K context, 8K output, GDPR-compliant, EU-hosted
PUBLIC_AI_API_KEY=...
PUBLIC_AI_BASE_URL=https://api.publicai.co/v1
PUBLIC_AI_MODEL=swiss-ai/apertus-8b-instruct
PUBLIC_AI_TEMPERATURE=0.8
PUBLIC_AI_TOP_P=0.9
PUBLIC_AI_MAX_TOKENS=8192

# ============================================================================
# Blockchain Configuration
# ============================================================================

# Ethereum
ETHEREUM_RPC_URL=https://eth.llamarpc.com
ETHEREUM_PRIVATE_KEY=0x...

# Polygon
POLYGON_RPC_URL=https://polygon-rpc.com
POLYGON_PRIVATE_KEY=0x...

# Solana
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_PRIVATE_KEY=...

# Wallet Configuration
DEFAULT_WALLET_ADDRESS=0x...

# ============================================================================
# External Services
# ============================================================================

# Email Service
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=...
SMTP_PASSWORD=...

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/agentdb

# Redis (for caching)
REDIS_URL=redis://localhost:6379

# ============================================================================
# Pipeline & Deployment
# ============================================================================

# Docker Registry
DOCKER_REGISTRY_URL=registry.example.com
DOCKER_USERNAME=...
DOCKER_PASSWORD=...

# Kubernetes
KUBECONFIG_PATH=~/.kube/config
K8S_NAMESPACE=default

# Deployment Notifications
DEPLOYMENT_WEBHOOK_URL=https://hooks.slack.com/services/...

# ============================================================================
# Monitoring & Observability
# ============================================================================

# Metrics Endpoint
METRICS_ENABLED=true
METRICS_PORT=9090

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# ============================================================================
# Security
# ============================================================================

# API Authentication
API_SECRET_KEY=...
JWT_SECRET=...

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

# ============================================================================
# Agent Configuration
# ============================================================================

# Orchestration
ORCHESTRATION_STRATEGY=autonomous
AUTO_EXECUTION_ENABLED=true
MAX_CONCURRENT_TASKS=10

# Vision
SCREEN_CAPTURE_ENABLED=true
SCREEN_CAPTURE_INTERVAL=1000
ENABLE_OCR=true
ENABLE_OBJECT_DETECTION=false

# Tools
ENABLE_WEB_SEARCH=true
ENABLE_CODE_EXECUTION=true
ENABLE_FILE_SYSTEM=true

# ============================================================================
# MCP Providers (Multi-Model Context Protocol)
# ============================================================================

# OpenRouter (100+ models)
OPENROUTER_API_KEY=...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Groq (Ultra-fast inference)
GROQ_API_KEY=...
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Together AI
TOGETHER_API_KEY=...
TOGETHER_BASE_URL=https://api.together.xyz/v1

# Ollama (Local models)
OLLAMA_BASE_URL=http://localhost:11434

# ============================================================================
# Computer Vision & Tools
# ============================================================================

# Cappy.ai
CAPPY_API_KEY=...

# OpenCV Configuration
OPENCV_ENABLED=true

# YOLO Configuration
YOLO_VERSION=v8

# ============================================================================
# OAuth Providers
# ============================================================================

# GitHub OAuth
GITHUB_CLIENT_ID=...
GITHUB_CLIENT_SECRET=...
GITHUB_REDIRECT_URI=http://localhost:3000/auth/callback/github

# Google OAuth
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback/google

# Slack OAuth
SLACK_CLIENT_ID=...
SLACK_CLIENT_SECRET=...
SLACK_REDIRECT_URI=http://localhost:3000/auth/callback/slack
SLACK_BOT_TOKEN=xoxb-...

# Notion OAuth
NOTION_CLIENT_ID=...
NOTION_CLIENT_SECRET=...
NOTION_API_KEY=...

# ============================================================================
# API Integrations
# ============================================================================

# GitHub API
GITHUB_TOKEN=ghp_...

# Airtable
AIRTABLE_API_KEY=...

# Stripe
STRIPE_SECRET_KEY=sk_...

# HubSpot
HUBSPOT_API_KEY=...

# Salesforce
SALESFORCE_INSTANCE_URL=https://your-domain.salesforce.com
SALESFORCE_ACCESS_TOKEN=...

# Linear
LINEAR_API_KEY=...

# Jira
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_API_TOKEN=...

# ============================================================================
# Development
# ============================================================================

NODE_ENV=development
DEBUG=true
