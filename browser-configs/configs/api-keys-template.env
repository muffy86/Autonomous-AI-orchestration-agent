# ================================
# AI API Keys Configuration
# ================================
# 
# SECURITY WARNING:
# - Never commit this file with real API keys
# - Add to .gitignore immediately
# - Use environment variables in production
# - Rotate keys regularly
# - Monitor API usage for anomalies
#
# Setup Instructions:
# 1. Copy this file to: ~/.ai-browser-config.env
# 2. Fill in your actual API keys
# 3. Load in terminal: source ~/.ai-browser-config.env
# 4. Or import into password manager
#
# ================================

# ===== OpenAI =====
# Get your key: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_ORG_ID=org-xxxxxxxxxxxxxxxxxxxxx

# ===== Anthropic (Claude) =====
# Get your key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===== xAI (Grok) =====
# Get your key: https://console.x.ai/
XAI_API_KEY=xai-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===== Google AI =====
# Get your key: https://makersuite.google.com/app/apikey
GOOGLE_AI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_AI_PROJECT_ID=your-project-id

# ===== Perplexity =====
# Get your key: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=pplx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===== Hugging Face =====
# Get your key: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===== Cohere =====
# Get your key: https://dashboard.cohere.com/api-keys
COHERE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===== Together AI =====
# Get your key: https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===== Replicate =====
# Get your key: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===== Stability AI =====
# Get your key: https://platform.stability.ai/account/keys
STABILITY_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===== ElevenLabs (Voice) =====
# Get your key: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===== GitHub =====
# Get your token: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_USERNAME=your-username

# ===== GitLab =====
# Get your token: https://gitlab.com/-/profile/personal_access_tokens
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===== Vector Databases =====

# Pinecone
PINECONE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
