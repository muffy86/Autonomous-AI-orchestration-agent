# ===== Monitoring & Analytics =====

# PostHog
POSTHOG_API_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Sentry
SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx

# LogTail
LOGTAIL_SOURCE_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===== Authentication =====

# Auth0
AUTH0_DOMAIN=your-domain.auth0.com
AUTH0_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AUTH0_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Clerk
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# NextAuth
NEXTAUTH_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXTAUTH_URL=http://localhost:3000

# ===== Cloud Storage =====

# AWS S3
AWS_ACCESS_KEY_ID=AKIA xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name

# Cloudflare R2
R2_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_BUCKET=your-bucket-name

# ===== Email Services =====

# Resend
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# SendGrid
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===== Payment =====

# Stripe
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===== Model-Specific Settings =====

# Default models to use
DEFAULT_CHAT_MODEL=gpt-4-turbo
DEFAULT_EMBEDDING_MODEL=text-embedding-3-small
DEFAULT_IMAGE_MODEL=dall-e-3
DEFAULT_VOICE_MODEL=tts-1

# API Settings
API_TIMEOUT=60000
API_MAX_RETRIES=3
API_RATE_LIMIT=60

# ===== Browser Extension Settings =====

# Extension IDs (for automation)
CHATGPT_EXTENSION_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GRAMMARLY_EXTENSION_ID=kbfnbcaeplbcioakkpcpgfkobkghlhen

# ===== Privacy & Security =====

# VPN/Proxy (if using)
HTTP_PROXY=http://proxy.example.com:8080
HTTPS_PROXY=https://proxy.example.com:8080
NO_PROXY=localhost,127.0.0.1

# Privacy settings
DO_NOT_TRACK=1
DNT=1

# ===== Feature Flags =====

# Enable/disable features
ENABLE_TELEMETRY=false
ENABLE_ANALYTICS=false
ENABLE_CRASH_REPORTS=false
ENABLE_EXPERIMENTS=true

# ===== Development =====

# Environment
NODE_ENV=development
DEBUG=true
LOG_LEVEL=info

# ===== Notes =====
#
# Import into browser:
# 1. For Tampermonkey scripts: Edit script → Storage tab → Import
# 2. For extensions: Use chrome.storage.local.set()
# 3. For web apps: Add to .env.local
#
# Secure storage options:
# - 1Password: Store as secure note
# - Bitwarden: Store in custom fields
# - LastPass: Store as secure note
# - OS Keychain: Use 'keyring' npm package
#
# Rotation schedule:
# - High-risk APIs (payments): Monthly
# - Medium-risk (AI services): Quarterly
# - Low-risk (read-only): Yearly
#
# Monitoring:
# - Set up billing alerts
# - Review usage regularly
# - Check for unusual patterns
# - Enable 2FA on all accounts
#
# Emergency:
# If keys are exposed:
# 1. Revoke immediately
# 2. Generate new keys
# 3. Update all apps
# 4. Review recent usage
# 5. Report if fraud detected
#
