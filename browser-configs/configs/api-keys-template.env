# Serper (Google Search API)
SERPER_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Brave Search API
BRAVE_SEARCH_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# SerpAPI
SERPAPI_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===== Development Tools =====

# Vercel
VERCEL_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Supabase
SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_SERVICE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Neon (Postgres)
DATABASE_URL=postgresql://user:pass@ep-xxxxx.us-east-2.aws.neon.tech/db

# Upstash (Redis)
UPSTASH_REDIS_URL=https://xxxxx.upstash.io
