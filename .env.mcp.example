# MCP Server Configuration
MCP_SERVER_PORT=3001
MCP_SERVER_NAME=ai-chatbot-mcp-server
MCP_SERVER_VERSION=1.0.0

# AI Provider API Keys
# Note: Many of these have free tiers or free credits

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# Anthropic Claude (https://console.anthropic.com/)
ANTHROPIC_API_KEY=

# Google Gemini (FREE TIER: https://makersuite.google.com/app/apikey)
GOOGLE_GENERATIVE_AI_API_KEY=

# xAI Grok (https://console.x.ai/)
XAI_API_KEY=

# Groq (FREE TIER: https://console.groq.com/keys)
GROQ_API_KEY=

# OpenRouter (FREE MODELS: https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# Together AI (FREE CREDITS: https://api.together.xyz/settings/api-keys)
TOGETHER_API_KEY=

# Hugging Face (FREE: https://huggingface.co/settings/tokens)
HUGGINGFACE_API_KEY=

# Replicate (FREE CREDITS: https://replicate.com/account/api-tokens)
REPLICATE_API_TOKEN=

# Public AI (SOVEREIGN, FREE, NO KEY REQUIRED: https://platform.publicai.co)
# Optional - works without key, but get one for higher limits
PUBLICAI_API_KEY=

# Webhook Configuration
WEBHOOK_SECRET=your-webhook-secret-here
GITHUB_WEBHOOK_SECRET=
SLACK_WEBHOOK_URL=
SLACK_BOT_TOKEN=
DISCORD_WEBHOOK_URL=

# Database (if using advanced features)
DATABASE_URL=

# Redis (for caching and rate limiting)
REDIS_URL=

# Security
AUTH_SECRET=
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60000

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Features
ENABLE_TOOLS=true
ENABLE_RESOURCES=true
ENABLE_PROMPTS=true
ENABLE_WEBHOOKS=true
ENABLE_SKILLS=true
ENABLE_CODE_EXECUTION=false

# Default Provider (use free tier by default)
DEFAULT_PROVIDER=google
DEFAULT_MODEL=gemini-2.0-flash-exp

# Fallback Providers (all free)
FALLBACK_PROVIDERS=groq,google,openrouter
